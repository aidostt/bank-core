# bank-core — environment reference (compose provides these; copy to .env to override)
# Every service fails fast at startup if a required variable is missing (CLAUDE.md §8).

# ---- shared ----
LOG_LEVEL=info                      # debug|info|warn|error

# ---- postgres (deploy/compose/init-db.sql creates db+user per service) ----
POSTGRES_PORT=5432
IDENTITY_DB_DSN=postgres://identity_user:identity_pass@localhost:5432/identity_db?sslmode=disable
ACCOUNT_DB_DSN=postgres://account_user:account_pass@localhost:5432/account_db?sslmode=disable
LEDGER_DB_DSN=postgres://ledger_user:ledger_pass@localhost:5432/ledger_db?sslmode=disable
TRANSFER_DB_DSN=postgres://transfer_user:transfer_pass@localhost:5432/transfer_db?sslmode=disable

# ---- kafka (redpanda) ----
KAFKA_BROKERS=localhost:19092

# ---- gateway ----
GATEWAY_HTTP_ADDR=:8080
GATEWAY_REDIS_ADDR=localhost:6379
GATEWAY_JWKS_URL=http://localhost:8081/.well-known/jwks.json
GATEWAY_IDENTITY_ADDR=localhost:9091
GATEWAY_ACCOUNT_ADDR=localhost:9092
GATEWAY_TRANSFER_ADDR=localhost:9094
GATEWAY_RATE_LIMIT_READS_RPS=10
GATEWAY_RATE_LIMIT_TRANSFERS_RPS=2

# ---- identity ----
IDENTITY_GRPC_ADDR=:9091
IDENTITY_HTTP_ADDR=:8081
IDENTITY_KEYS_DIR=./.keys            # RSA keypair volume; generated on first boot
IDENTITY_ACCESS_TOKEN_TTL=15m
IDENTITY_REFRESH_TOKEN_TTL=720h      # 30d
IDENTITY_JWT_ISSUER=bank-core-identity

# ---- account ----
ACCOUNT_GRPC_ADDR=:9092
ACCOUNT_HTTP_ADDR=:8082
ACCOUNT_LEDGER_ADDR=localhost:9093

# ---- ledger ----
LEDGER_GRPC_ADDR=:9093
LEDGER_HTTP_ADDR=:8083
LEDGER_HOLD_DEFAULT_TTL=10m

# ---- transfer ----
TRANSFER_GRPC_ADDR=:9094
TRANSFER_HTTP_ADDR=:8084
TRANSFER_LEDGER_ADDR=localhost:26093 # through toxiproxy (chaos demo, M3)
TRANSFER_ACCOUNT_ADDR=localhost:9092
TRANSFER_RECOVERY_INTERVAL=5s
TRANSFER_RECOVERY_STALE_AFTER=15s

# ---- antifraud / notification (consumers land in M2) ----
ANTIFRAUD_HTTP_ADDR=:8085
NOTIFICATION_HTTP_ADDR=:8086
