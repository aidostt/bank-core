{
  "uid": "platform-red",
  "title": "Platform RED",
  "tags": ["bank-core"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate (gateway)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP error rate (5xx)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "gRPC request rate by service method",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (job, method) (rate(grpc_requests_total[1m]))",
          "legendFormat": "{{job}} {{method}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "gRPC p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(grpc_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "gRPC non-OK responses",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (job, code) (rate(grpc_requests_total{code!=\"OK\"}[1m]))",
          "legendFormat": "{{job}} {{code}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
