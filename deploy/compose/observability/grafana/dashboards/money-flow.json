{
  "uid": "money-flow",
  "title": "Money Flow",
  "tags": ["bank-core"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Transfers by terminal state",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (state) (increase(transfers_total[1m]))",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Ledger postings",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(ledger_postings_total[1m])",
          "legendFormat": "postings"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Outbox lag (unsent rows)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (job) (outbox_lag)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Consumer lag",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (job, topic) (consumer_lag)",
          "legendFormat": "{{job}} {{topic}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Fraud alerts by severity",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (severity) (increase(fraud_alerts_total[5m]))",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Notifications",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (increase(notifications_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
